graph TD
    Candidate((Candidate))
    Recruiter((Recruiter))

    subgraph Frontend["React + Vite Frontend"]
        PublicJobs["Job Search and Job Detail"]
        CandidateApp["Resume, Applications, Messages"]
        RecruiterApp["Dashboard, Pipeline, Messages"]
        SocketClient["Socket.io Client"]
    end

    subgraph Backend["Express Modular Monolith"]
        REST["REST API"]
        Auth["Clerk + Recruiter JWT Middleware"]
        Validation["Joi Validation"]
        AIService["AI Resume Service"]
        SocketHub["Socket.io Hub"]
        Swagger["Swagger UI"]
    end

    subgraph Data["Data and External Services"]
        Mongo[(MongoDB)]
        Redis[(Redis Cache)]
        Cloudinary[(Private Resume Storage)]
        Gemini[(Gemini API)]
    end

    Candidate --> PublicJobs
    Candidate --> CandidateApp
    Recruiter --> RecruiterApp

    PublicJobs --> REST
    CandidateApp --> REST
    RecruiterApp --> REST
    CandidateApp --> SocketClient
    RecruiterApp --> SocketClient

    REST --> Auth
    Auth --> Validation
    Validation --> Mongo
    REST --> Cloudinary
    REST --> AIService
    AIService --> Redis
    AIService --> Gemini
    REST --> Swagger

    SocketClient <--> SocketHub
    SocketHub --> Auth
    SocketHub --> Mongo
