graph TD
    User((Candidate))
    Recruiter((Recruiter))
    
    subgraph Frontend ["Frontend Layer (React 18 + Vite)"]
        UI[UI Components / Kanban]
        Context[AppContext / Token Mgmt]
        Hooks[Custom Hooks / useSocket]
        SocketClient[Socket.io Client]
    end
    
    subgraph Security ["Security & Documentation"]
        Swagger[Swagger UI / api-docs]
        Multer[Multer / PDF & Img Filter]
        RateLimit[Express Rate Limiter]
        Clerk[Clerk Auth / JWT Middleware]
    end
    
    subgraph Backend ["Backend Layer (Node.js + Express)"]
        API[REST API Endpoints]
        SocketHub[Socket.io Hub / Rooms]
        AI[AI Service / Gemini NLP]
    end
    
    subgraph Data ["Data & Optimization Layer"]
        Mongo[(MongoDB Atlas)]
        Redis[(Upstash Redis Cache)]
        Cloudinary[(Cloudinary Storage)]
    end
    
    %% Connections
    User -->|Interaction| UI
    Recruiter -->|Interaction| UI
    
    UI --> Context
    UI --> SocketClient
    
    Context -->|HTTPS| RateLimit
    RateLimit --> Clerk
    Clerk --> API
    
    API --> Swagger
    API --> Multer
    Multer --> Cloudinary
    
    API --> Mongo
    API --> AI
    AI -->|Cache Match| Redis
    
    SocketClient <--> SocketHub
    SocketHub --> Redis
    SocketHub <--> User
    SocketHub <--> Recruiter
